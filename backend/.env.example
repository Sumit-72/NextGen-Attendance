# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Session & security secrets (generate with: openssl rand -base64 32)
JWT_SESSION_SECRET=change-me-to-a-long-random-secret
OTP_PEPPER=change-me-to-a-random-pepper
QR_TOKEN_SECRET=change-me-to-another-random-secret

# Firebase Admin SDK (from Firebase Console > Project settings > Service accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
